#!/usr/bin/env python3

import argparse
import json
import math
import pathlib
import sys


MIN_CONTRAST_RATIO = 4.5
BLACK = "#000000"
WHITE = "#FFFFFF"


def parse_args(argv):
    parser = argparse.ArgumentParser(
        description="Generate contrast-safe i3 colors from the active pywal palette."
    )
    cache_dir = pathlib.Path.home() / ".cache" / "wal"
    parser.add_argument(
        "--input",
        type=pathlib.Path,
        default=cache_dir / "colors.json",
        help="Path to pywal's colors.json cache.",
    )
    parser.add_argument(
        "--output",
        type=pathlib.Path,
        default=cache_dir / "colors-i3.Xresources",
        help="Path to write the derived i3 Xresources file.",
    )
    return parser.parse_args(argv)


def hex_to_rgb(value):
    stripped = value.strip().lstrip("#")
    if len(stripped) != 6:
        raise ValueError(f"expected #RRGGBB color, got {value!r}")
    return tuple(int(stripped[index : index + 2], 16) for index in range(0, 6, 2))


def rgb_to_hex(rgb):
    return "#" + "".join(f"{max(0, min(255, round(channel))):02X}" for channel in rgb)


def mix(color_a, color_b, weight):
    rgb_a = hex_to_rgb(color_a)
    rgb_b = hex_to_rgb(color_b)
    return rgb_to_hex(
        tuple(channel_a * (1 - weight) + channel_b * weight for channel_a, channel_b in zip(rgb_a, rgb_b))
    )


def _channel_to_linear(channel):
    normalized = channel / 255
    if normalized <= 0.03928:
        return normalized / 12.92
    return ((normalized + 0.055) / 1.055) ** 2.4


def relative_luminance(color):
    red, green, blue = hex_to_rgb(color)
    red_linear = _channel_to_linear(red)
    green_linear = _channel_to_linear(green)
    blue_linear = _channel_to_linear(blue)
    return 0.2126 * red_linear + 0.7152 * green_linear + 0.0722 * blue_linear


def contrast_ratio(color_a, color_b):
    luminance_a = relative_luminance(color_a)
    luminance_b = relative_luminance(color_b)
    lighter = max(luminance_a, luminance_b)
    darker = min(luminance_a, luminance_b)
    return (lighter + 0.05) / (darker + 0.05)


def choose_readable_foreground(background):
    black_ratio = contrast_ratio(background, BLACK)
    white_ratio = contrast_ratio(background, WHITE)
    if black_ratio >= white_ratio:
        return BLACK, black_ratio
    return WHITE, white_ratio


def nudge_for_contrast(background, foreground):
    best_background = background
    best_ratio = contrast_ratio(background, foreground)
    if best_ratio >= MIN_CONTRAST_RATIO:
        return best_background, best_ratio

    target = BLACK if foreground == BLACK else WHITE
    for step in range(1, 26):
        candidate = mix(background, target, step / 25)
        ratio = contrast_ratio(candidate, foreground)
        if ratio > best_ratio:
            best_background = candidate
            best_ratio = ratio
        if ratio >= MIN_CONTRAST_RATIO:
            return candidate, ratio

    return best_background, best_ratio


def make_contrast_safe_pair(background):
    foreground, ratio = choose_readable_foreground(background)
    adjusted_background, adjusted_ratio = nudge_for_contrast(background, foreground)
    if adjusted_ratio > ratio:
        return adjusted_background, foreground
    return background, foreground


def build_resource_map(palette):
    special = palette["special"]
    colors = palette["colors"]

    base_bg = special["background"].upper()
    base_text = special["foreground"].upper()
    if contrast_ratio(base_bg, base_text) < MIN_CONTRAST_RATIO:
        base_text = choose_readable_foreground(base_bg)[0]

    focus_bg, focus_text = make_contrast_safe_pair(colors["color2"].upper())
    active_bg, active_text = make_contrast_safe_pair(colors["color4"].upper())
    inactive_candidate = mix(base_bg, colors["color8"].upper(), 0.35)
    inactive_bg, inactive_text = make_contrast_safe_pair(inactive_candidate)

    return {
        "i3wm.ui.base_bg": base_bg,
        "i3wm.ui.text": base_text,
        "i3wm.ui.focus_bg": focus_bg,
        "i3wm.ui.focus_text": focus_text,
        "i3wm.ui.active_bg": active_bg,
        "i3wm.ui.active_text": active_text,
        "i3wm.ui.inactive_bg": inactive_bg,
        "i3wm.ui.inactive_text": inactive_text,
    }


def write_xresources(path, resource_map):
    lines = [
        "! i3 colors derived from pywal.",
        "! Generated by executable_generate-i3-pywal-colors",
    ]
    for key, value in resource_map.items():
        lines.append(f"{key}: {value}")
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text("\n".join(lines) + "\n", encoding="utf-8")


def main(argv=None):
    args = parse_args(argv if argv is not None else sys.argv[1:])
    try:
        palette = json.loads(args.input.read_text(encoding="utf-8"))
        resource_map = build_resource_map(palette)
        write_xresources(args.output, resource_map)
    except FileNotFoundError as exc:
        print(f"Error: Missing input palette file: {exc.filename}", file=sys.stderr)
        return 1
    except (KeyError, ValueError, json.JSONDecodeError) as exc:
        print(f"Error: Unable to derive i3 colors from pywal output: {exc}", file=sys.stderr)
        return 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
